# Copy to .env.production on the VPS. Never commit the real file.
# `postgres` is the PostgreSQL container name on the shared traefik-public
# Docker network. db.conexus.tech serves pgAdmin, not PostgreSQL itself.
DATABASE_URL="postgresql://conexus_admin:YOUR_PASSWORD@postgres:5432/conexus_site"
JWT_SECRET="generate-with-openssl-rand-base64-64"

RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="contato@conexus.tech"
RESEND_NOTIFY_EMAIL="contato@conexus.tech"

NEXT_PUBLIC_APP_URL="https://conexus.tech"
NEXT_PUBLIC_APP_NAME="Conexus"
NODE_ENV="production"
