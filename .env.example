# ─── Database (PostgreSQL - Supabase, Railway, Neon, local…) ──────────────────
# Any Postgres works. SSL is auto-enabled for non-local hosts (Supabase/Neon/
# Railway) and off for localhost - no code changes needed.
#
# Supabase: Dashboard → "Connect" → "Connection string" → URI.
#   Recommended (Session pooler, supports DDL + seed):
#   postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
#
# Railway: provided automatically when you add the PostgreSQL plugin.
# Local Docker: postgresql://conexus:conexus123@localhost:5432/conexus
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ─── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"

# Senha do usuário admin criado pelo seed (npm run seed). Defina uma senha forte
# antes de rodar o seed; troque depois pelo painel. Nunca versione a senha real.
SEED_ADMIN_PASSWORD="defina-uma-senha-forte"

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Get your key at https://resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# The verified domain email address configured in Resend
RESEND_FROM_EMAIL="contato@conexus.com.br"
# Where lead notifications are sent internally
RESEND_NOTIFY_EMAIL="conexus@seudominio.com.br"

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Conexus"
NODE_ENV="development"

# ─── Analytics (add after going live) ─────────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
